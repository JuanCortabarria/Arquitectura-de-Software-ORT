# Copiá este archivo como ".env" y completá los valores
# cp .env.example .env

# Puerto en el que corre el servidor
PORT=4000

# URL base de la API externa de precios (CryptoCompare)
CRYPTO_API_URL=https://min-api.cryptocompare.com/data/price

# MySQL (Sequelize) — persistencia relacional para Asset
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=secret
MYSQL_DATABASE=crypto_portfolio

# MongoDB (Mongoose) — persistencia documental para AuditLog
MONGODB_URI=mongodb://localhost:27017/crypto_portfolio
