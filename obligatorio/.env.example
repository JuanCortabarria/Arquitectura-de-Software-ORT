# ============================================================================
# MOVE — Plataforma de Traslados Urbanos · variables de entorno
# Copiá este archivo como .env y ajustá los valores para tu entorno local.
# ============================================================================

# --- PostgreSQL ---
POSTGRES_USER=move
POSTGRES_PASSWORD=move_local_dev
POSTGRES_DB=move
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- move-api (NestJS monolith) ---
MOVE_API_PORT=3000
MOVE_API_LOG_LEVEL=info
JWT_PUBLIC_KEY_URL=http://auth-provider:8080/.well-known/jwks.json
JWT_ISSUER=move-auth
JWT_AUDIENCE=move-api
RATE_LIMIT_REQUESTS_PER_MINUTE=200

# --- move-classification (FastAPI) ---
CLASSIFICATION_PORT=8001
# Estrategia activa: tfidf | semantic | ollama
CLASSIFICATION_STRATEGY=tfidf
CLASSIFICATION_THRESHOLD=0.35
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b

# --- move-gps-ingestion (Fastify) ---
GPS_INGESTION_PORT=3001
GPS_DEVICE_CACHE_TTL_SECONDS=60

# --- move-monitoring (Node) ---
MONITORING_PORT=3002
DETENCION_UMBRAL_MINUTOS=5
ZONES_CACHE_RELOAD_CHANNEL=zones:updated

# --- Payment simulator ---
# success | reject | pending | timeout
PAYMENT_SIMULATOR_MODE=success
PAYMENT_RECONCILIATION_INTERVAL_MINUTES=5

# --- Email (modo mock por defecto en desarrollo) ---
# mock | smtp
EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- GPS simulator (script externo) ---
GPS_SIM_DEVICES=5
GPS_SIM_INTERVAL_MS=10000
GPS_SIM_MODE=route

# --- Observability ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003
GRAFANA_ADMIN_PASSWORD=admin
